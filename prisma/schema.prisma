generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
}

model Bot {
  id              String   @id @default(uuid())
  name            String   // Ví dụ: "Zalo Finance Bot", "Telegram Personal Bot"
  platform        Platform // Enum: ZALO hoặc TELEGRAM
  token           String?  @unique // Dùng cho Telegram hoặc Zalo OA
  sessionData     Json?    // Dùng để lưu thông tin zca-js (cookie, imei, userAgent)
  webhookSecret   String?  // Dùng để verify tin nhắn gửi tới từ Zalo/Telegram
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Quan hệ: Một Bot xử lý nhiều giao dịch và tin nhắn
  transactions    Transaction[]
  messages        Message[]
}

model User {
  id              String   @id @default(uuid())
  telegramId      String?  @unique
  zaloId          String?  @unique
  fullName        String?
  avatar            String?
  createdAt       DateTime @default(now())
  
  transactions    Transaction[]
  messages        Message[]

  @@index([telegramId, zaloId])
}

model Message {
  id              String         @id @default(uuid())
  botId           String
  bot             Bot            @relation(fields: [botId], references: [id])
  
  userId          String
  user            User           @relation(fields: [userId], references: [id])
  
  content         String?        @db.Text
  msgType         String?        // webchat, chat.photo, ...
  direction       MessageDirection
  
  // Lưu metadata thô từ bot nếu cần
  rawPayload      Json?

  createdAt       DateTime       @default(now())

  @@index([userId, createdAt])
}

enum MessageDirection {
  INCOMING // Từ người dùng tới Bot
  OUTGOING // Từ Bot tới người dùng
}

model Transaction {
  id                String         @id @default(uuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id])
  
  // Liên kết với con Bot đã thu thập giao dịch này
  botId             String
  bot               Bot            @relation(fields: [botId], references: [id])

  amount            Decimal        @db.Decimal(15, 2)
  currency          String         @default("VND")
  vendor            String?
  category          Category       @default(OTHERS)
  transactionDate   DateTime       @default(now())
  
  imageUrl          String?
  rawOcrText        String?        @db.Text
  aiMetadata        Json?          

  createdAt         DateTime       @default(now())

  @@index([userId, transactionDate])
}

enum Platform {
  ZALO
  TELEGRAM
}

enum Category {
  FOOD_DRINK
  TRANSPORT
  SHOPPING
  BILLS
  HEALTH
  ENTERTAINMENT
  OTHERS
}
